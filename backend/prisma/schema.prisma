generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  passwordHash     String?    @map("password_hash")
  name             String
  companyName      String?    @map("company_name")
  taxNumber        String?    @map("tax_number")
  phone            String?
  avatarUrl        String?    @map("avatar_url")
  subscriptionTier String     @default("free") @map("subscription_tier")
  stripeCustomerId String?    @map("stripe_customer_id")
  microsecToken    String?    @map("microsec_token")
  dapLinked        Boolean    @default(false) @map("dap_linked")
  role             String     @default("user") // superadmin | employee | user
  notifyOnSign     Boolean    @default(true) @map("notify_on_sign")
  notifyOnDecline  Boolean    @default(true) @map("notify_on_decline")
  notifyOnExpire   Boolean    @default(true) @map("notify_on_expire")
  notifyOnComment  Boolean    @default(true) @map("notify_on_comment")
  notifyOnComplete Boolean    @default(true) @map("notify_on_complete")
  notifyMarketing  Boolean    @default(false) @map("notify_marketing")
  emailDigest      String     @default("instant") @map("email_digest") // instant | daily | weekly | none
  brandLogoUrl     String?    @map("brand_logo_url")
  brandColor       String?    @map("brand_color") // hex color for PDF branding
  savedSignatureUrl String?   @map("saved_signature_url")
  savedStampUrl     String?   @map("saved_stamp_url")
  consentGivenAt   DateTime?  @map("consent_given_at")
  consentVersion   String?    @map("consent_version") // e.g. "2026-03-01"
  consentIp        String?    @map("consent_ip")
  emailVerified    Boolean    @default(false) @map("email_verified")
  emailVerifyToken String?    @map("email_verify_token")
  emailVerifyExp   DateTime?  @map("email_verify_exp")
  twoFactorEnabled Boolean    @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?    @map("two_factor_secret")
  twoFactorBackup  String[]   @default([]) @map("two_factor_backup")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  contracts   Contract[]
  templates   Template[]
  teamMembers TeamMember[]
  ownedTeams  Team[]
  apiKeys     ApiKey[]
  comments    Comment[]
  webhooks      Webhook[]
  tags          Tag[]
  folders       Folder[]
  contacts      Contact[]
  notifications Notification[]
  sessions      Session[]
  passwordResets PasswordReset[]
  referralsSent Referral[] @relation("ReferralsSent")
  referralsReceived Referral[] @relation("ReferralsReceived")
  quotes          Quote[]
  quoteTemplates  QuoteTemplate[]
  invoices        Invoice[]
  companies       Company[]
  failedLoginAttempts Int      @default(0) @map("failed_login_attempts")
  lockedUntil      DateTime?  @map("locked_until")
  googleId         String?    @unique @map("google_id")
  oauthProvider    String?    @map("oauth_provider")
  autoInvoice     Boolean    @default(false) @map("auto_invoice")
  trialEndsAt      DateTime?  @map("trial_ends_at")
  onboardingCompleted Boolean @default(false) @map("onboarding_completed")
  authorizedSigners AuthorizedSigner[]
  emailLogs       EmailLog[]
  apiUsageLogs    ApiUsageLog[]
  promoCodeUsages PromoCodeUsage[]
  sendCredits     Int        @default(0) @map("send_credits")
  creditTransactions CreditTransaction[]
  authAuditLogs   AuthAuditLog[]
  accountType     String     @default("company") @map("account_type") // "personal" or "company"
  companyAddress  String?    @map("company_address")
  isActive        Boolean    @default(true) @map("is_active")
  deactivatedAt   DateTime?  @map("deactivated_at")

  @@map("users")
}

model CreditTransaction {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  amount      Int      // positive = purchase, negative = usage
  balance     Int      // balance after transaction
  type        String   // purchase | usage | admin_grant | refund
  description String?
  contractId  String?  @map("contract_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contract Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("credit_transactions")
}

model AuthorizedSigner {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  name           String
  email          String
  title          String?  // e.g. "Ügyvezető", "Cégvezető", "HR vezető"
  companyName    String?  @map("company_name")
  companyTaxNumber String? @map("company_tax_number")
  companyAddress String?  @map("company_address")
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("authorized_signers")
}

model Team {
  id        String   @id @default(uuid())
  name      String
  ownerId   String   @map("owner_id")
  plan      String   @default("free") // free | basic | pro
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner   User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members TeamMember[]

  @@map("teams")
}

model TeamMember {
  id     String @id @default(uuid())
  teamId String @map("team_id")
  userId String @map("user_id")
  role   String @default("member") // admin | member | viewer
  joinedAt DateTime @default(now()) @map("joined_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model ApiKey {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  keyHash   String   @unique @map("key_hash")
  prefix    String   // first 8 chars for identification
  lastUsed  DateTime? @map("last_used")
  expiresAt DateTime? @map("expires_at")
  scopes    String   @default("contracts:read") // comma-separated: contracts:read,contracts:write,templates:read
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@map("api_keys")
}

model Template {
  id            String   @id @default(uuid())
  name          String
  category      String
  description   String?
  contentHtml   String   @map("content_html")
  contentHtmlEn String?  @map("content_html_en")
  variables     String
  isPublic      Boolean  @default(true) @map("is_public")
  ownerId       String?  @map("owner_id")
  legalBasis    String?  @map("legal_basis")
  createdAt     DateTime @default(now()) @map("created_at")

  owner     User?              @relation(fields: [ownerId], references: [id])
  contracts Contract[]
  versions  TemplateVersion[]

  @@map("templates")
}

model TemplateVersion {
  id          String   @id @default(uuid())
  templateId  String   @map("template_id")
  version     Int
  contentHtml String   @map("content_html")
  changeNote  String?  @map("change_note")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("template_versions")
}

model Contract {
  id               String    @id @default(uuid())
  title            String
  registrationNumber String? @unique @map("registration_number") // Iktatószám: 20260311-1643-V912-4020708-1164582
  templateId       String?   @map("template_id")
  ownerId          String    @map("owner_id")
  contentHtml      String    @map("content_html")
  pdfUrl           String?   @map("pdf_url")
  status           String    @default("draft")
  variablesData    String?   @map("variables_data")
  folderId         String?   @map("folder_id")
  verificationHash String?   @unique @map("verification_hash")
  documentHash     String?   @map("document_hash") // SHA-256 hash of the PDF
  variablesHash    String?   @map("variables_hash") // SHA-256 hash of variables data
  expiresAt        DateTime? @map("expires_at")
  renewalDate      DateTime? @map("renewal_date")
  renewalType      String?   @map("renewal_type") // auto | manual | none
  renewalNotifiedAt DateTime? @map("renewal_notified_at")
  tsaToken         String?   @map("tsa_token") // RFC 3161 timestamp token (base64 DER)
  tsaTimestamp     DateTime? @map("tsa_timestamp") // Verified timestamp from TSA
  tsaAuthority     String?   @map("tsa_authority") // TSA server used
  tsaSerialNumber  String?   @map("tsa_serial_number")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  workflowId  String?   @map("workflow_id")

  template  Template?          @relation(fields: [templateId], references: [id])
  owner     User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  folder    Folder?            @relation(fields: [folderId], references: [id])
  workflow  ApprovalWorkflow?  @relation(fields: [workflowId], references: [id])
  signers   Signer[]
  auditLogs AuditLog[]
  comments  Comment[]
  tags      ContractTag[]
  versions  ContractVersion[]
  reminders ContractReminder[]
  creditTransactions CreditTransaction[]
  approvals Approval[]
  invoices  Invoice[]
  bulkOperation   BulkOperation? @relation(fields: [bulkOperationId], references: [id])
  bulkOperationId String?        @map("bulk_operation_id")

  @@index([ownerId])
  @@index([status])
  @@map("contracts")
}

model Signer {
  id                String    @id @default(uuid())
  contractId        String    @map("contract_id")
  name              String
  email             String
  role              String?
  signingOrder      Int       @default(1) @map("signing_order")
  signToken         String?   @unique @map("sign_token")
  tokenExpiresAt    DateTime? @map("token_expires_at")
  status            String    @default("pending")
  signedAt          DateTime? @map("signed_at")
  ipAddress         String?   @map("ip_address")
  userAgent         String?   @map("user_agent")
  signatureMethod   String?   @map("signature_method")
  signatureImageUrl String?   @map("signature_image_url")
  stampImageUrl     String?   @map("stamp_image_url")
  typedName         String?   @map("typed_name")
  certificateData   String?   @map("certificate_data")
  signerNote        String?   @map("signer_note")
  companyName       String?   @map("company_name")
  companyTaxNumber  String?   @map("company_tax_number")
  companyAddress    String?   @map("company_address")
  contactId         String?   @map("contact_id")
  otpCode           String?   @map("otp_code")
  otpExpiresAt      DateTime? @map("otp_expires_at")
  otpVerified       Boolean   @default(false) @map("otp_verified")
  otpAttempts       Int       @default(0) @map("otp_attempts")
  createdAt         DateTime  @default(now()) @map("created_at")

  contract  Contract   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contact   Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  auditLogs AuditLog[]

  @@index([signToken])
  @@index([contractId])
  @@map("signers")
}

model AuditLog {
  id            String   @id @default(uuid())
  contractId    String   @map("contract_id")
  signerId      String?  @map("signer_id")
  eventType     String   @map("event_type")
  eventData     String?  @map("event_data")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  documentHash  String?  @map("document_hash")
  integrityHash String?  @map("integrity_hash")
  previousHash  String?  @map("previous_hash")
  createdAt     DateTime @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  signer   Signer?  @relation(fields: [signerId], references: [id], onDelete: SetNull)

  @@index([contractId])
  @@map("audit_logs")
}

model Comment {
  id         String   @id @default(uuid())
  contractId String   @map("contract_id")
  userId     String   @map("user_id")
  content    String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("comments")
}

model Tag {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#6B7280")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contracts ContractTag[]

  @@unique([userId, name])
  @@map("tags")
}

model ContractTag {
  id         String   @id @default(uuid())
  contractId String   @map("contract_id")
  tagId      String   @map("tag_id")
  createdAt  DateTime @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contractId, tagId])
  @@map("contract_tags")
}

model ContractVersion {
  id          String   @id @default(uuid())
  contractId  String   @map("contract_id")
  version     Int
  contentHtml String   @map("content_html")
  pdfUrl      String?  @map("pdf_url")
  changeNote  String?  @map("change_note")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("contract_versions")
}

model Session {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  tokenHash   String   @map("token_hash")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  device      String?  // parsed from user-agent
  lastActive  DateTime @default(now()) @map("last_active")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("sessions")
}

model Referral {
  id            String    @id @default(uuid())
  referrerId    String    @map("referrer_id")
  referralCode  String    @unique @map("referral_code")
  referredEmail String?   @map("referred_email")
  referredId    String?   @map("referred_id")
  bonusApplied  Boolean   @default(false) @map("bonus_applied")
  createdAt     DateTime  @default(now()) @map("created_at")
  convertedAt   DateTime? @map("converted_at")

  referrer User @relation("ReferralsSent", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User? @relation("ReferralsReceived", fields: [referredId], references: [id])

  @@index([referrerId])
  @@map("referrals")
}

model Folder {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#6B7280")
  userId    String   @map("user_id")
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Folder?    @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[]   @relation("FolderTree")
  contracts Contract[]

  @@unique([userId, name, parentId])
  @@map("folders")
}

model Contact {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  email       String
  company     String?
  phone       String?
  taxNumber   String?  @map("tax_number")
  address     String?
  notes       String?
  group       String?  // Ügyfelek, Beszállítók, Alvállalkozók, Partnerek, Egyéb
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  signers   Signer[]
  companies ContactCompany[]

  @@unique([userId, email])
  @@map("contacts")
}

model Company {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  taxNumber   String?  @map("tax_number")
  address     String?
  phone       String?
  email       String?
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts ContactCompany[]

  @@unique([userId, name])
  @@map("companies")
}

model ContactCompany {
  id        String   @id @default(uuid())
  contactId String   @map("contact_id")
  companyId String   @map("company_id")
  role      String?  // Ügyvezető, Kapcsolattartó, Pénzügyi, stb.
  createdAt DateTime @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([contactId, companyId])
  @@map("contact_companies")
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  used      Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("password_resets")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   // contract_signed, contract_completed, contract_declined, contract_expired, reminder, system
  title     String
  message   String
  link      String?
  data      String?  // JSON extra data
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model Webhook {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  url             String
  secret          String
  events          String    // comma-separated: contract.created,contract.signed,contract.completed,contract.declined,contract.expired,quote.sent,quote.accepted,quote.declined,quote.converted
  active          Boolean   @default(true)
  lastError       String?   @map("last_error")
  lastTriggeredAt DateTime? @map("last_triggered_at")
  failedCount     Int       @default(0) @map("failed_count")
  createdAt       DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryLogs WebhookDeliveryLog[]

  @@map("webhooks")
}

model Quote {
  id            String    @id @default(uuid())
  ownerId       String    @map("owner_id")
  templateId    String?   @map("template_id")
  title         String
  clientName    String    @map("client_name")
  clientEmail   String    @map("client_email")
  clientCompany String?   @map("client_company")
  clientPhone   String?   @map("client_phone")
  clientAddress String?   @map("client_address")
  clientTaxNumber String? @map("client_tax_number")
  status        String    @default("draft") // draft | sent | accepted | declined | expired
  viewToken     String?   @unique @map("view_token") // public viewing token
  quoteNumber   String?   @map("quote_number") // e.g. AJ-2026-0001
  validUntil    DateTime? @map("valid_until")
  currency      String    @default("HUF")
  language      String    @default("hu")
  introText     String?   @map("intro_text")
  outroText     String?   @map("outro_text")
  notes         String?
  discount      Float?    // global discount value
  discountType  String?   @map("discount_type") // percent | fixed
  variablesData String?   @map("variables_data") // JSON string of template variables
  version       Int       @default(1)
  declineReason String?   @map("decline_reason")
  acceptedAt    DateTime? @map("accepted_at")
  declinedAt    DateTime? @map("declined_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  owner    User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  template QuoteTemplate? @relation(fields: [templateId], references: [id])
  items    QuoteItem[]
  comments QuoteComment[]

  @@index([ownerId])
  @@index([viewToken])
  @@map("quotes")
}

model QuoteItem {
  id           String  @id @default(uuid())
  quoteId      String  @map("quote_id")
  description  String
  quantity     Float   @default(1)
  unitPrice    Float   @map("unit_price")
  unit         String  @default("db") // db, ora, honap, nap, projekt, oldal, km
  taxRate      Float   @default(27) @map("tax_rate") // percentage
  sectionName  String? @map("section_name") // grouping label
  isOptional   Boolean @default(false) @map("is_optional")
  discount     Float?  // item-level discount value
  discountType String? @map("discount_type") // percent | fixed
  sortOrder    Int     @default(0) @map("sort_order")

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@map("quote_items")
}

model QuoteComment {
  id        String   @id @default(uuid())
  quoteId   String   @map("quote_id")
  author    String   // client name or "owner"
  isOwner   Boolean  @default(false) @map("is_owner")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  @@index([quoteId])
  @@map("quote_comments")
}

model ContractReminder {
  id          String   @id @default(uuid()) @map("id")
  contractId  String   @map("contract_id")
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  type        String   // "expiry", "renewal", "signing_deadline", "custom"
  message     String
  remindAt    DateTime @map("remind_at")
  sent        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([contractId])
  @@index([remindAt])
  @@map("contract_reminders")
}

model QuoteTemplate {
  id          String   @id @default(uuid())
  ownerId     String   @map("owner_id")
  name        String
  description String?
  category    String   @default("altalanos") // altalanos, it, marketing, epiteszet, tanácsadás, etc.
  currency    String   @default("HUF")
  introText   String?  @map("intro_text")
  outroText   String?  @map("outro_text")
  itemsJson   String   @map("items_json") // JSON array of template line items
  variables   String?  // JSON array of variable definitions [{key, label, type, defaultValue}]
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner  User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  quotes Quote[]

  @@index([ownerId])
  @@map("quote_templates")
}

model Invoice {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  quoteId         String?   @map("quote_id")
  contractId      String?   @map("contract_id")
  contract        Contract? @relation(fields: [contractId], references: [id])
  provider        String    @default("szamlazzhu") // billingo | szamlazzhu
  externalId      String?   @map("external_id") // provider-side ID
  invoiceNumber   String?   @map("invoice_number")
  amount          Float
  currency        String    @default("HUF")
  taxRate         Float     @default(27) @map("tax_rate")
  partnerName     String    @map("partner_name")
  partnerEmail    String?   @map("partner_email")
  buyerName       String    @map("buyer_name")
  buyerEmail      String    @map("buyer_email")
  buyerTaxNumber  String?   @map("buyer_tax_number")
  status          String    @default("draft") // draft | pending | issued | sent | paid | failed | cancelled
  issuedAt        DateTime? @map("issued_at")
  dueAt           DateTime? @map("due_at")
  pdfUrl          String?   @map("pdf_url")
  errorMessage    String?   @map("error_message")
  szamlazzId      String?   @map("szamlazz_id") // legacy external reference
  createdAt       DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quoteId])
  @@index([contractId])
  @@map("invoices")
}

model EmailLog {
  id         String   @id @default(uuid())
  to         String
  subject    String
  type       String   // signing_invitation | signed_confirmation | reminder | verification | password_reset | quote
  status     String   @default("sent") // sent | delivered | bounced | complained | failed
  resendId   String?  @map("resend_id")
  userId     String?  @map("user_id")
  contractId String?  @map("contract_id")
  error      String?
  metadata   String?  // JSON
  openedAt   DateTime? @map("opened_at")
  clickedAt  DateTime? @map("clicked_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("email_logs")
}

model ApiUsageLog {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  apiKeyId       String?  @map("api_key_id")
  method         String   // GET | POST | PATCH | DELETE
  path           String
  statusCode     Int      @map("status_code")
  responseTimeMs Int      @map("response_time_ms")
  ip             String?
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([apiKeyId])
  @@index([createdAt])
  @@map("api_usage_logs")
}

model SystemBroadcast {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   @default("info") // info | warning | success | maintenance
  active    Boolean  @default(true)
  createdBy String   @map("created_by")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([active])
  @@map("system_broadcasts")
}

model PromoCode {
  id            String    @id @default(uuid())
  code          String    @unique
  description   String?
  discountType  String    @map("discount_type") // percent | fixed | tier_upgrade | trial_days
  discountValue Float     @map("discount_value") // percentage, HUF amount, or days
  targetTier    String?   @map("target_tier") // for tier_upgrade: which tier to grant
  maxUses       Int?      @map("max_uses")
  usedCount     Int       @default(0) @map("used_count")
  validFrom     DateTime? @map("valid_from")
  validUntil    DateTime? @map("valid_until")
  active        Boolean   @default(true)
  createdBy     String    @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")

  usages PromoCodeUsage[]

  @@map("promo_codes")
}

model PromoCodeUsage {
  id          String   @id @default(uuid())
  promoCodeId String   @map("promo_code_id")
  userId      String   @map("user_id")
  appliedAt   DateTime @default(now()) @map("applied_at")

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
  @@map("promo_code_usages")
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(true)
  minTier     String?  @map("min_tier") // null = all tiers, otherwise: free | starter | medium | premium | enterprise
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

model WebhookDeliveryLog {
  id           String   @id @default(uuid())
  webhookId    String   @map("webhook_id")
  event        String
  url          String
  statusCode   Int?     @map("status_code")
  responseBody String?  @map("response_body")
  error        String?
  attempt      Int      @default(1)
  success      Boolean  @default(false)
  durationMs   Int?     @map("duration_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([createdAt])
  @@map("webhook_delivery_logs")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model AuthAuditLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  action    String   // login | login_failed | logout | 2fa_enabled | 2fa_disabled | password_changed | account_deleted
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  metadata  String?  // JSON extra data
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("auth_audit_logs")
}

model ApprovalWorkflow {
  id          String   @id @default(uuid())
  name        String
  teamId      String   @map("team_id")
  steps       ApprovalStep[]
  contracts   Contract[]
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("approval_workflows")
}

model ApprovalStep {
  id            String   @id @default(uuid())
  workflowId    String   @map("workflow_id")
  workflow      ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  order         Int
  name          String
  approverEmail String   @map("approver_email")
  approverName  String?  @map("approver_name")
  approvals     Approval[]

  @@map("approval_steps")
}

model Approval {
  id          String    @id @default(uuid())
  contractId  String    @map("contract_id")
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  stepId      String    @map("step_id")
  step        ApprovalStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  status      String    @default("pending") // pending | approved | rejected | skipped
  comment     String?
  decidedBy   String?   @map("decided_by")
  decidedAt   DateTime? @map("decided_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("approvals")
}

model Clause {
  id          String   @id @default(uuid())
  title       String
  content     String   // HTML content
  category    String   // e.g. "titoktartás", "felelősség", "fizetés", "GDPR"
  tags        String[] @default([])
  teamId      String?  @map("team_id")
  userId      String   @map("user_id")
  isDefault   Boolean  @default(false) @map("is_default") // system-provided clauses
  usageCount  Int      @default(0) @map("usage_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([category])
  @@map("clauses")
}

model PortalInvitation {
  id          String   @id @default(uuid())
  email       String
  token       String   @unique
  teamId      String   @map("team_id")
  invitedBy   String   @map("invited_by")
  status      String   @default("pending") // pending, accepted, revoked
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@map("portal_invitations")
}

model BulkOperation {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  templateId    String   @map("template_id")
  totalCount    Int      @map("total_count")
  successCount  Int      @default(0) @map("success_count")
  failCount     Int      @default(0) @map("fail_count")
  status        String   @default("pending") // pending | processing | completed | failed
  errorLog      String?  @map("error_log") // JSON array of errors
  createdAt     DateTime @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")

  contracts Contract[]

  @@index([userId])
  @@map("bulk_operations")
}

model TestResult {
  id          String   @id @default(uuid())
  testId      String   @unique @map("test_id")
  status      String   @default("pending") // pending | in_progress | pass | fail | blocked
  assignedTo  String?  @map("assigned_to")
  notes       String?
  screenshots String[] @default([])
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([assignedTo])
  @@map("test_results")
}
