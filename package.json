{
  "name": "legitas",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run start:dev --workspace=backend",
    "build": "npm run build --workspace=frontend && npm run build --workspace=backend",
    "lint": "npm run lint --workspace=frontend && npm run lint --workspace=backend",
    "test": "npm test --workspace=backend",
    "test:e2e": "npx playwright test",
    "test:e2e:auth": "source .env.e2e && npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "precheck": "npm run build --workspace=frontend && npm test --workspace=backend && npx playwright test",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.0"
  }
}
