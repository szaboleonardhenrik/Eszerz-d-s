#!/bin/bash
echo "🔍 Pre-commit: Quick checks..."

# Only lint staged NEW frontend files (not modified existing files with pre-existing errors)
STAGED_NEW=$(git diff --cached --name-only --diff-filter=A | grep '^frontend/src/.*\.\(ts\|tsx\)$' | sed 's|^frontend/||' || true)

if [ -n "$STAGED_NEW" ]; then
  echo "📝 Linting new frontend files..."
  cd frontend && npx eslint $STAGED_NEW && cd ..
  if [ $? -ne 0 ]; then
    echo "❌ Lint errors in new files! Fix before committing."
    exit 1
  fi
fi

echo "✅ Pre-commit checks passed."
